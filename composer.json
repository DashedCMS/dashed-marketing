{
    "name": "dashed/dashed-marketing",
    "description": "Marketing module for Dashed CMS — social media, keyword research, content drafts, SEO",
    "keywords": ["Dashed", "laravel", "dashed-marketing", "social-media"],
    "homepage": "https://github.com/Dashed-DEV/dashed-marketing",
    "license": "MIT",
    "authors": [{"name": "Robin van Maasakker", "email": "robin@dashed.nl", "role": "Developer"}],
    "require": {
        "php": "^8.4",
        "dashed/dashed-ai": "*",
        "dashed/dashed-core": "*",
        "maatwebsite/excel": "^3.1",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "filament/upgrade": "^4.0",
        "friendsofphp/php-cs-fixer": "^3.63",
        "orchestra/testbench": "^9",
        "pestphp/pest": "^3.5",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Dashed\\DashedMarketing\\": "src",
            "Dashed\\DashedMarketing\\Database\\Factories\\": "database/factories"
        }
    },
    "autoload-dev": {"psr-4": {"Dashed\\DashedMarketing\\Tests\\": "tests"}},
    "scripts": {"test": "vendor/bin/pest", "test-coverage": "vendor/bin/pest coverage"},
    "config": {"sort-packages": true, "allow-plugins": {"pestphp/pest-plugin": true}},
    "extra": {"laravel": {"providers": ["Dashed\\DashedMarketing\\DashedMarketingServiceProvider"]}},
    "minimum-stability": "dev",
    "prefer-stable": true
}